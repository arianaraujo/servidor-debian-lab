;
; BIND reverse data file for local loopback interface
;
$TTL    604800
@       IN      SOA     ns.lab.local. aaraujo.lab.local. (
                              1         ; Serial
                         604800         ; Refresh
                          86400         ; Retry
                        2419200         ; Expire
                         604800 )       ; Negative Cache TTL
;
@       IN      NS      localhost.
1.0.0   IN      PTR     localhost.
14      IN      PTR     srv-debian.lab.local.